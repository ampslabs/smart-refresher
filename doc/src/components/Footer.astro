---

---

<footer class="site-footer">
  <div class="footer-content">
    <div class="footer-left">
      <span class="copyright">© {new Date().getFullYear()} smart_refresher</span
      >
    </div>
    <div class="footer-center">
      <p class="made-with">
        Created with <span class="heart">❤️</span> by <a
          href="https://aditi.cc"
          class="ampslabs-link">aditi.cc</a
        >
      </p>
    </div>
    <div class="footer-right">
      <div class="footer-status">
        <span class="status-dot"></span>
        <span>Stable v1.0.0</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 4rem 2rem;
    border-top: 1px solid var(--sl-color-gray-5);
    margin-top: 1rem;
    background: rgba(var(--sl-color-bg-rgb), 0.5);
    backdrop-filter: blur(10px);
  }

  .footer-content {
    max-width: var(--sl-content-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
  }

  .footer-center {
    flex: 1;
    text-align: center;
  }

  .made-with {
    font-weight: 500;
  }

  .heart {
    color: #ff4d4d;
    display: inline-block;
    animation: heartBeat 1.5s ease-in-out infinite;
    margin: 0 0.2rem;
  }

  @keyframes heartBeat {
    0% {
      transform: scale(1);
    }
    14% {
      transform: scale(1.3);
    }
    28% {
      transform: scale(1);
    }
    42% {
      transform: scale(1.3);
    }
    70% {
      transform: scale(1);
    }
  }

  .ampslabs-link {
    color: var(--sl-color-text);
    text-decoration: none;
    font-weight: 700;
    transition: color 0.2s;
  }

  .ampslabs-link:hover {
    color: var(--sl-color-accent);
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(var(--sl-color-gray-5-rgb), 0.1);
    padding: 0.4rem 0.8rem;
    border-radius: 99rem;
    border: 1px solid var(--sl-color-gray-5);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 8px #10b981;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
  }
</style>
